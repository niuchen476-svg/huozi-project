PORT=3001

# 允许跨域访问的前端源，逗号分隔（默认放行本地 vite 开发端口）
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# CADAL / 图书馆 API（如有）
CADAL_API_BASE=
CADAL_API_KEY=

# AI 能力所需的密钥（如 OCR / RAG / LLM）
ANTHROPIC_API_KEY=

# 小米 MiMo 大模型（用于"推断-验证锁"机制）
MIMO_API_KEY=
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5

# AIHubMix 图片生成（默认关闭，确认额度后再改为 true）
AIHUBMIX_API_BASE=https://aihubmix.com/v1
AIHUBMIX_API_KEY=
AIHUBMIX_IMAGE_MODEL=qwen-image-2.0
AIHUBMIX_IMAGE_ENABLED=false
AIHUBMIX_IMAGE_DAILY_LIMIT=10
